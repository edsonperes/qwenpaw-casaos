# Copie para .env e ajuste. Usado por `docker compose up -d`.
# (No CasaOS, esses valores sao editados pela interface da App Store.)

# --- Dono da imagem no GHCR (seu usuario/org do GitHub) ---
GHCR_OWNER=edsonperes

# --- Autenticacao do console (OBRIGATORIA em servidor publico) ---
QWENPAW_AUTH_ENABLED=true
QWENPAW_AUTH_USERNAME=admin
# Gere uma senha forte, ex.: openssl rand -base64 24
QWENPAW_AUTH_PASSWORD=troque-esta-senha

# --- Personalizacoes ---
# Idioma padrao do assistente/interface.
QWENPAW_DEFAULT_LANGUAGE=pt-BR
# Backend de transcricao: local_whisper | whisper_api | disabled
QWENPAW_TRANSCRIPTION_TYPE=local_whisper
# Modelo do Whisper local: base | small | medium (small/medium baixam no 1o uso)
QWENPAW_WHISPER_MODEL=base

# --- Reaplica os padroes acima mesmo se ja semeado antes (debug) ---
# QWENPAW_SEED_FORCE=true
